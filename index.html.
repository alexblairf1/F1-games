<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>F1 Hub — cl16isthebest</title>
    <!-- Linking to your CSS file -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Header with logo and your coin count -->
    <header class="site-header">
        <div class="logo">F1<span>HUB</span></div>
        <div class="coin-display">
            <span class="coin-icon">🪙</span>
            <span id="coin-count" class="coin-val">500</span>
        </div>
    </header>

    <!-- Navigation buttons to switch between pages -->
    <nav class="main-nav">
        <button class="nav-btn active" onclick="showPage('home')">Home</button>
        <button class="nav-btn" onclick="showPage('collection')">Collection</button>
        <button class="nav-btn" onclick="showPage('simulation')">Race Sim</button>
        <button class="nav-btn" onclick="showPage('quiz')">Daily Quiz</button>
        <button class="nav-btn" onclick="showPage('shop')">Shop</button>
    </nav>

    <!-- Home Page: News and Achievements -->p
    <main id="home" class="page active">
        <div class="card">
            <h2>Next Grand Prix</h2>
            <p id="countdown">Don't worry, F1 will be back! Next Race: <strong>Miami Grand Prix - May 4, 2025</strong></p>
        </div>
        <div class="card">
            <h3>Recent Achievements</h3>
            <div id="helmet-unlocks">Win races to unlock historic helmets!</div>
        </div>
    </main>

    <!-- Collection Page: Where your cards and duplicates live -->
    <main id="collection" class="page">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h2>Your Garage</h2>
            <button class="btn btn-red" onclick="sellDuplicates()">Sell All Duplicates</button>
        </div>
        <div id="card-grid" class="grid4">
            <!-- Cards are generated here by script.js -->
        </div>
    </main>

    <!-- Simulation Page: Pit strategy and the chaos factor -->
    <main id="simulation" class="page">
        <div class="card">
            <h3>Race Strategy</h3>
            <p style="margin-bottom: 15px; font-size: 14px; color: #aaa;">Choose your setup for the next race:</p>
            <div class="grid3">
                <button class="btn tyre-soft" onclick="setStrategy('Aggressive')">Aggressive</button>
                <button class="btn tyre-med" onclick="setStrategy('Balanced')">Balanced</button>
                <button class="btn tyre-hard" onclick="setStrategy('Conservative')">Conservative</button>
            </div>
            <button class="btn btn-red btn-full" style="margin-top:20px; padding: 15px;" onclick="startRace()">Start Race Simulation</button>
        </div>
        <div id="race-results" class="card" style="display:none;">
            <h3>Race Summary</h3>
            <div id="results-list"></div>
        </div>
    </main>

    <!-- Quiz Page: 15 daily questions -->
    <main id="quiz" class="page">
        <div class="card">
            <h2>Daily Pro Quiz</h2>
            <p style="color: #888; margin-bottom: 20px;">Complete 15 questions to earn up to 100 bonus coins!</p>
            <div id="quiz-container">
                <!-- Quiz content generated by script.js -->
            </div>
        </div>
    </main>

    <!-- Shop Page: Card packs and special editions -->
    <main id="shop" class="page">
        <div class="pack-grid">
            <div class="pack-card" onclick="buyPack('Standard')">
                <div class="pack-icon pack-silver">P</div>
                <div class="pack-name">Standard Pack</div>
                <div class="pack-cost">500 Coins</div>
            </div>
            <div id="special-pack" class="pack-card" style="border: 2px solid #c89b3c; display:none;" onclick="buyPack('Hero')">
                <div class="pack-icon pack-legend">★</div>
                <div class="pack-name">HERO DRIVE PACK</div>
                <div class="pack-cost">7500 Coins</div>
                <p style="font-size: 10px; color: #c89b3c; margin-top: 5px;">25% Chance for 100 Rated Card</p>
            </div>
        </div>
    </main>

    <!-- Linking to your JavaScript logic -->
    <script src="script.js"></script>
</body>
</html>

